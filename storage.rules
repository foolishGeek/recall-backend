rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public staging APK for BillDesk / merchant review only.
    match /public/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
